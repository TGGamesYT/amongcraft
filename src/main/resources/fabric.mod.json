{
  "schemaVersion": 1,
  "id": "amongcraft",
  "version": "${version}",
  "name": "AmongCraft",
  "description": "Among Us in Minecraft",
  "authors": ["TGGamesYT"],
  "contact": {
    "website": "https://tg.is-a.dev",
    "source": "https://github.com/tggamesyt/amongcraft",
    "issues": "https://github.com/tggamesyt/amongcraft/issues"
  },
  "license": "MIT",
  "icon": "assets/amongcraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "me.tg.amongcraft.client.AmongcraftDataGenerator"
    ],
    "client": [
      "me.tg.amongcraft.client.AmongcraftClient"
    ],
    "main": [
      "me.tg.amongcraft.Amongcraft"
    ]
  },
  "mixins": [
    "amongcraft.mixins.json",
