  "modmenu": {
    "links": {
      "modmenu.discord": "https://discord.gg/8v6NvACFX5"
    },
    "parent": {
      "id": "amongcraft",
      "name": "AmongCraft",
      "description": "Among Us in Minecraft",
      "icon": "assets/amongcraft/icon.png"
    },
    "update_checker": true
  }
